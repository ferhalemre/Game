{
  "name": "klan-savasi",
  "version": "1.0.0",
  "description": "Three.js Tribal Wars style browser strategy game",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "seed": "node server/scripts/seedWorld.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "vite": "^5.4.8"
  }
}
